                <zone fixed-size='280' h='92245' id='10' is-fixed='true' name='The Heat Map of Engagement' w='32892' x='66625' y='6815'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone h='8578' id='11' name='The Heat Map of Engagement' pane-specification-id='0' param='[federated.11atu2r1niqx8q15yk0ve18xflv8].[sum:F1:qk]' type-v2='color' w='20821' x='17984' y='20211'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='16804' id='12' type-v2='text' w='20821' x='17984' y='28789'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>INTERPRETATION:</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>Chart 1</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>This gives a high-level view of the data&apos;s emotional balance. It immediately shows if the dataset is skewed toward &quot;Negative&quot; or &quot;Neutral&quot; feedback.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='16804' id='13' type-v2='text' w='20821' x='17984' y='45593'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>INTERPRETATION:</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>Chart 2</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>This is the &quot;Product Health&quot; view. It allows you to see which specific games (like </run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' italic='true'>Borderlands</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>) or brands have a higher &quot;red&quot; (Negative) bar compared to others.</run>
                    <run>Æ&#10;</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='16804' id='14' type-v2='text' w='20821' x='17984' y='62397'>
                  <formatted-text>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>INTERPRETATION:</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>Chart 3</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book'>Darker squares indicate &quot;hotspots&quot; of activity. For example, if &quot;Nvidia&quot; has a very dark square under &quot;Positive,&quot; it indicates a highly successful sentiment pocket.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>

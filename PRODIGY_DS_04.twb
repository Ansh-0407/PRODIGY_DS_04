                <zone h='13396' id='8' name='Sentiment Distribution' pane-specification-id='0' param='[federated.11atu2r1niqx8q15yk0ve18xflv8].[none:F3:nk]' type-v2='color' w='20821' x='17984' y='6815'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
